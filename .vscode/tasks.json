{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev: Start",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "group": "devServer"
      },
      "runOptions": {
        "instanceLimit": 1
      }
    },
    {
      "label": "Dev: Open Preview",
      "type": "shell",
      "command": "echo Ouvrir http://localhost:5173/barsabruz/ dans Simple Browser",
      "dependsOn": "Dev: Start",
      "presentation": {
        "reveal": "never"
      }
    }
  ]
}
